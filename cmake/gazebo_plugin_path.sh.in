# Generated by intention_gazebo CMakeLists.txt — adds our install lib dir
# (where the virtual_hand_joint_driver plugin .so lives) to
# GAZEBO_PLUGIN_PATH so gzserver can locate the plugin when referenced
# from a URDF.

if [ -z "$GAZEBO_PLUGIN_PATH" ]; then
  export GAZEBO_PLUGIN_PATH="@CMAKE_INSTALL_PREFIX@/lib"
else
  export GAZEBO_PLUGIN_PATH="@CMAKE_INSTALL_PREFIX@/lib:$GAZEBO_PLUGIN_PATH"
fi
