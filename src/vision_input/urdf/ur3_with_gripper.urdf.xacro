<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="ur3_with_robotiq">

  <xacro:arg name="name" default="ur"/>
  <xacro:arg name="ur_type" default="ur3"/>

  <xacro:include filename="$(find ur_description)/urdf/ur.urdf.xacro"/>
  
  <xacro:include filename="$(find robotiq_description)/urdf/robotiq_2f_85_macro.urdf.xacro"/>

  <xacro:robotiq_gripper name="RobotiqGripper" prefix="" parent="tool0">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:robotiq_gripper>

</robot>