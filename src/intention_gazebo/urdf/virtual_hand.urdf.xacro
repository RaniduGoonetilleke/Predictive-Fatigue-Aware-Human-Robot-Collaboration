<?xml version="1.0"?>
<!--
  Virtual operator hand for intention-sharing research.

  Adapted from the LinkerHand L25 right-hand URDF and STL meshes:
    https://github.com/linker-bot/linkerhand-urdf
  Licensed under the Apache License 2.0. A copy of the license and
  attribution notice are bundled in meshes/linkerhand/.

  Modifications from the original L25 URDF:
    - Added virtual_hand_base_link root for attachment to world/tool frame
    - Reduced all link masses and inertia to cosmetic values (visual-only)
    - Disabled gravity and added blue transparent materials via <gazebo> tags
    - Replaced thumb_mcp lower-limit typo ("0-") with "0"
    - Index distal link colored green as fingertip indicator
    - Collision geometries removed (visualization only)
-->
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="virtual_hand">

  <!--  MATERIALS  -->
  <material name="hand_blue">
    <color rgba="0.3 0.5 1.0 0.7"/>
  </material>
  <material name="fingertip_green">
    <color rgba="0.2 1.0 0.3 0.9"/>
  </material>

  <!--  PROPERTIES -->
  <xacro:property name="mesh_pkg" value="package://intention_gazebo/meshes/linkerhand"/>
  <xacro:property name="tiny_mass" value="0.0001"/>
  <xacro:property name="tiny_inertia" value="1e-8"/>

  <!--  TINY INERTIAL MACRO  -->
  <xacro:macro name="tiny_inertial">
    <inertial>
      <mass value="${tiny_mass}"/>
      <inertia ixx="${tiny_inertia}" iyy="${tiny_inertia}" izz="${tiny_inertia}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!--  GAZEBO LINK MACRO  -->
  <xacro:macro name="gz_visual" params="link_name transparency:=0.3">
    <gazebo reference="${link_name}">
      <gravity>false</gravity>
      <visual>
        <transparency>${transparency}</transparency>
        <material>
          <ambient>0.3 0.5 1.0 1.0</ambient>
          <diffuse>0.3 0.5 1.0 1.0</diffuse>
          <specular>0.1 0.2 0.5 1.0</specular>
        </material>
      </visual>
    </gazebo>
  </xacro:macro>

 
  <!-- ROOT LINK                                                   -->
 

  <!-- Invisible root attached to world/tool frame -->
  <link name="virtual_hand_base_link"/>

  <!-- Fixed joint connecting our root to L25's hand_base_link -->
  <joint name="virtual_hand_root_joint" type="fixed">
    <parent link="virtual_hand_base_link"/>
    <child link="hand_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <!-- HAND BASE                                                   -->


  <link name="hand_base_link">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/hand_base_link.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
    <!-- Tiny dummy collision so Gazebo keeps the link in its model tree -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </collision>
  </link>

  <xacro:gz_visual link_name="hand_base_link"/>


  <!-- THUMB  (5 joints: cmc_roll → cmc_yaw → cmc_pitch →        -->
  <!--          mcp → ip)                                         -->
 

  <joint name="thumb_cmc_roll" type="revolute">
    <origin xyz="-0.016602 0.001612 0.071287" rpy="0 0 0"/>
    <parent link="hand_base_link"/>
    <child link="thumb_metacarpals_base1"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.46" upper="0.61" effort="0" velocity="6.28"/>
  </joint>

  <link name="thumb_metacarpals_base1">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/thumb_metacarpals_base1.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="thumb_cmc_yaw" type="revolute">
    <origin xyz="0.04625 0.0083829 4.7486E-05" rpy="0 0 0"/>
    <parent link="thumb_metacarpals_base1"/>
    <child link="thumb_metacarpals_base2"/>
    <axis xyz="0 0.0056645 -0.99998"/>
    <limit lower="0" upper="1.57" effort="0" velocity="6.28"/>
  </joint>

  <link name="thumb_metacarpals_base2">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/thumb_metacarpals_base2.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="thumb_cmc_pitch" type="revolute">
    <origin xyz="0.006883 0.014309 0.0015936" rpy="0 0 0"/>
    <parent link="thumb_metacarpals_base2"/>
    <child link="thumb_metacarpals"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.59" effort="0" velocity="6.28"/>
  </joint>

  <link name="thumb_metacarpals">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/thumb_metacarpals.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="thumb_mcp" type="revolute">
    <origin xyz="0 0.034264 -0.0037526" rpy="0 0 0"/>
    <parent link="thumb_metacarpals"/>
    <child link="thumb_proximal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.59" effort="0" velocity="6.28"/>
  </joint>

  <link name="thumb_proximal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/thumb_proximal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="thumb_ip" type="revolute">
    <origin xyz="0 0.046252 -0.0020512" rpy="0 0 0"/>
    <parent link="thumb_proximal"/>
    <child link="thumb_distal"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.78" effort="0" velocity="6.28"/>
  </joint>

  <link name="thumb_distal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/thumb_distal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <xacro:gz_visual link_name="thumb_metacarpals_base1"/>
  <xacro:gz_visual link_name="thumb_metacarpals_base2"/>
  <xacro:gz_visual link_name="thumb_metacarpals"/>
  <xacro:gz_visual link_name="thumb_proximal"/>
  <xacro:gz_visual link_name="thumb_distal"/>


  <!-- INDEX FINGER  (4 joints: mcp_roll → mcp_pitch → pip → dip)-->


  <joint name="index_mcp_roll" type="revolute">
    <origin xyz="0.0014984 0.032141 0.13508" rpy="0 0 0"/>
    <parent link="hand_base_link"/>
    <child link="index_metacarpals"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.24" upper="0.24" effort="0" velocity="6.28"/>
  </joint>

  <link name="index_metacarpals">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/index_metacarpals.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="index_mcp_pitch" type="revolute">
    <origin xyz="0.0068598 -0.00010189 0.018075" rpy="0 0 0"/>
    <parent link="index_metacarpals"/>
    <child link="index_proximal"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.68" effort="0" velocity="6.28"/>
  </joint>

  <link name="index_proximal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/index_proximal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="index_pip" type="revolute">
    <origin xyz="-0.0001598 -0.00024924 0.043999" rpy="0 0 0"/>
    <parent link="index_proximal"/>
    <child link="index_middle"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.27" effort="0" velocity="6.28"/>
  </joint>

  <link name="index_middle">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/index_middle.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="index_dip" type="revolute">
    <origin xyz="0.00099206 -0.00025106 0.044322" rpy="0 0 0"/>
    <parent link="index_middle"/>
    <child link="index_distal"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.78" effort="0" velocity="6.28"/>
  </joint>

  <link name="index_distal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/index_distal.STL"/>
      </geometry>
      <!-- Green indicator on index fingertip -->
      <material name="fingertip_green"/>
    </visual>
  </link>

  <xacro:gz_visual link_name="index_metacarpals"/>
  <xacro:gz_visual link_name="index_proximal"/>
  <xacro:gz_visual link_name="index_middle"/>

  <!-- Index distal: bright green indicator in Gazebo -->
  <gazebo reference="index_distal">
    <gravity>false</gravity>
    <visual>
      <transparency>0.1</transparency>
      <material>
        <ambient>0.2 1.0 0.3 1.0</ambient>
        <diffuse>0.2 1.0 0.3 1.0</diffuse>
        <specular>0.5 1.0 0.5 1.0</specular>
      </material>
    </visual>
  </gazebo>


  <!-- MIDDLE FINGER                                              -->

  <joint name="middle_mcp_roll" type="revolute">
    <origin xyz="0.0014985 0.0099581 0.14231" rpy="0 0 0"/>
    <parent link="hand_base_link"/>
    <child link="middle_metacarpals"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.24" upper="0.24" effort="0" velocity="6.28"/>
  </joint>

  <link name="middle_metacarpals">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/middle_metacarpals.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="middle_mcp_pitch" type="revolute">
    <origin xyz="0.0068598 -0.00010189 0.018075" rpy="0 0 0"/>
    <parent link="middle_metacarpals"/>
    <child link="middle_proximal"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.68" effort="0" velocity="6.28"/>
  </joint>

  <link name="middle_proximal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/middle_proximal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="middle_pip" type="revolute">
    <origin xyz="-0.0001598 -0.00024924 0.043999" rpy="0 0 0"/>
    <parent link="middle_proximal"/>
    <child link="middle_middle"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.27" effort="0" velocity="6.28"/>
  </joint>

  <link name="middle_middle">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/middle_middle.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="middle_dip" type="revolute">
    <origin xyz="0.00099206 -0.00025106 0.044322" rpy="0 0 0"/>
    <parent link="middle_middle"/>
    <child link="middle_distal"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.78" effort="0" velocity="6.28"/>
  </joint>

  <link name="middle_distal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/middle_distal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <xacro:gz_visual link_name="middle_metacarpals"/>
  <xacro:gz_visual link_name="middle_proximal"/>
  <xacro:gz_visual link_name="middle_middle"/>
  <xacro:gz_visual link_name="middle_distal"/>


  <!-- RING FINGER                                                -->

  <joint name="ring_mcp_roll" type="revolute">
    <origin xyz="0.0014987 -0.011555 0.13457" rpy="0 0 0"/>
    <parent link="hand_base_link"/>
    <child link="ring_metacarpals"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.24" upper="0.24" effort="0" velocity="6.28"/>
  </joint>

  <link name="ring_metacarpals">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/ring_metacarpals.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="ring_mcp_pitch" type="revolute">
    <origin xyz="0.0068598 -0.00010189 0.018075" rpy="0 0 0"/>
    <parent link="ring_metacarpals"/>
    <child link="ring_proximal"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.68" effort="0" velocity="6.28"/>
  </joint>

  <link name="ring_proximal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/ring_proximal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="ring_pip" type="revolute">
    <origin xyz="-0.0001598 -0.00024924 0.043999" rpy="0 0 0"/>
    <parent link="ring_proximal"/>
    <child link="ring_middle"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.27" effort="0" velocity="6.28"/>
  </joint>

  <link name="ring_middle">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/ring_middle.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="ring_dip" type="revolute">
    <origin xyz="0.00099206 -0.00025106 0.044322" rpy="0 0 0"/>
    <parent link="ring_middle"/>
    <child link="ring_distal"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.78" effort="0" velocity="6.28"/>
  </joint>

  <link name="ring_distal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/ring_distal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <xacro:gz_visual link_name="ring_metacarpals"/>
  <xacro:gz_visual link_name="ring_proximal"/>
  <xacro:gz_visual link_name="ring_middle"/>
  <xacro:gz_visual link_name="ring_distal"/>


  <!-- PINKY FINGER                                               -->

  <joint name="pinky_mcp_roll" type="revolute">
    <origin xyz="0.0014989 -0.033485 0.1194" rpy="0 0 0"/>
    <parent link="hand_base_link"/>
    <child link="pinky_metacarpals"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.24" upper="0.24" effort="0" velocity="6.28"/>
  </joint>

  <link name="pinky_metacarpals">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/pinky_metacarpals.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="pinky_mcp_pitch" type="revolute">
    <origin xyz="0.0068598 -0.00010189 0.018075" rpy="0 0 0"/>
    <parent link="pinky_metacarpals"/>
    <child link="pinky_proximal"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.68" effort="0" velocity="6.28"/>
  </joint>

  <link name="pinky_proximal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/pinky_proximal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="pinky_pip" type="revolute">
    <origin xyz="-0.0001598 -0.00024924 0.043999" rpy="0 0 0"/>
    <parent link="pinky_proximal"/>
    <child link="pinky_middle"/>
    <axis xyz="0 0.99998 -0.0056645"/>
    <limit lower="0" upper="1.27" effort="0" velocity="6.28"/>
  </joint>

  <link name="pinky_middle">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/pinky_middle.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <joint name="pinky_dip" type="revolute">
    <origin xyz="0.00099206 -0.00025106 0.044322" rpy="0 0 0"/>
    <parent link="pinky_middle"/>
    <child link="pinky_distal"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.78" effort="0" velocity="6.28"/>
  </joint>

  <link name="pinky_distal">
    <xacro:tiny_inertial/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_pkg}/pinky_distal.STL"/>
      </geometry>
      <material name="hand_blue"/>
    </visual>
  </link>

  <xacro:gz_visual link_name="pinky_metacarpals"/>
  <xacro:gz_visual link_name="pinky_proximal"/>
  <xacro:gz_visual link_name="pinky_middle"/>
  <xacro:gz_visual link_name="pinky_distal"/>

  <!--
    Custom Gazebo model plugin (built from src/virtual_hand_joint_driver.cpp).
    Owns the entire virtual_hand model state at runtime:
      - Subscribes to /virtual_hand/joint_states → Model::SetJointPositions
        (finger animation, non-disruptive: bypasses the physics solver and
        does not affect any other model in the world).
      - Subscribes to /virtual_hand/base_pose → re-applies Model::SetWorldPose
        every physics tick. This both moves the hand around the workstation
        AND prevents the slow rotation that would otherwise build up from the
        reaction torques of snapping fingers on a free-floating base.
  -->
  <gazebo>
    <plugin name="virtual_hand_joint_driver"
            filename="libvirtual_hand_joint_driver.so">
      <joint_topic>/virtual_hand/joint_states</joint_topic>
      <pose_topic>/virtual_hand/base_pose</pose_topic>
    </plugin>
  </gazebo>

</robot>
