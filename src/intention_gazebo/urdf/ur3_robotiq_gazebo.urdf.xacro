<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="ur3_intention_system">

  
  <!-- Arguments                                    -->
  
  <xacro:arg name="simulation_controllers" default=""/>
  <!-- REMOVED: initial_positions_file — not supported in Humble ur_description -->

  
  <!-- World link                                   -->
  
  <link name="world"/>

  
  <!-- UR3 Robot                                    -->
  
  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>

  <xacro:ur_robot
    name="ur3"
    tf_prefix=""
    parent="world"
    joint_limits_parameters_file="$(find ur_description)/config/ur3/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur3/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur3/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur3/visual_parameters.yaml"
    sim_gazebo="true"
  >
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:ur_robot>

  
  <!-- Robotiq 2F-85 Gripper                        -->
  
  <xacro:include filename="$(find robotiq_description)/urdf/robotiq_2f_85_macro.urdf.xacro"/>

  <xacro:robotiq_gripper
    name="robotiq_85"
    prefix=""
    parent="tool0"
    include_ros2_control="false"
  >
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:robotiq_gripper>


  <!-- Gripper ros2_control for Gazebo              -->

  <ros2_control name="GripperGazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="robotiq_85_left_knuckle_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.8</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Right knuckle: mimic multiplier=-1 -->
    <joint name="robotiq_85_right_knuckle_joint">
      <command_interface name="position">
        <param name="min">-0.8</param>
        <param name="max">0.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Inner knuckle and finger tip joints — continuous, controlled to drive full linkage -->
    <joint name="robotiq_85_left_inner_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="robotiq_85_right_inner_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="robotiq_85_left_finger_tip_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="robotiq_85_right_finger_tip_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>


  <!-- Gazebo ros2_control plugin (ONCE only)       -->

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(arg simulation_controllers)</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>


  <!-- Stabilize gripper mimic joints               -->

  <xacro:macro name="gripper_joint_stabilizer" params="joint_name">
    <gazebo reference="${joint_name}">
      <implicitSpringDamper>true</implicitSpringDamper>
      <springStiffness>500</springStiffness>
      <springDamping>50</springDamping>
    </gazebo>
  </xacro:macro>

  <!-- Gripper finger springs REMOVED — the 500 N/m stiffness was
       overpowering the position controller commands, locking the
       finger_tip joints at 0 and causing the V-shape pinch. -->

  <!-- Disable gravity on arm links (prevents sagging in sim) -->
  <gazebo reference="shoulder_link"><gravity>false</gravity></gazebo>
  <gazebo reference="upper_arm_link"><gravity>false</gravity></gazebo>
  <gazebo reference="forearm_link"><gravity>false</gravity></gazebo>
  <gazebo reference="wrist_1_link"><gravity>false</gravity></gazebo>
  <gazebo reference="wrist_2_link"><gravity>false</gravity></gazebo>
  <gazebo reference="wrist_3_link"><gravity>false</gravity></gazebo>

  <!-- Add viscous damping to arm joints — absorbs physics micro-oscillations
       caused by zero-gravity + position control in ODE. springStiffness=0
       means pure damping with no restoring force. -->
  <xacro:macro name="arm_joint_damper" params="joint_name">
    <gazebo reference="${joint_name}">
      <implicitSpringDamper>true</implicitSpringDamper>
      <springStiffness>0.0</springStiffness>
      <springDamping>5.0</springDamping>
    </gazebo>
  </xacro:macro>

  <xacro:arm_joint_damper joint_name="shoulder_pan_joint"/>
  <xacro:arm_joint_damper joint_name="shoulder_lift_joint"/>
  <xacro:arm_joint_damper joint_name="elbow_joint"/>
  <xacro:arm_joint_damper joint_name="wrist_1_joint"/>
  <xacro:arm_joint_damper joint_name="wrist_2_joint"/>
  <xacro:arm_joint_damper joint_name="wrist_3_joint"/>


  <!-- Gripper pad friction — prevents objects      -->
  <!-- slipping through the Robotiq fingers         -->

  <!-- High friction + contact stiffness on ALL gripper contact surfaces -->
  <xacro:macro name="gripper_contact" params="link_name">
    <gazebo reference="${link_name}">
      <mu1>100.0</mu1>
      <mu2>100.0</mu2>
      <kp>1000000.0</kp>
      <kd>1.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>
  </xacro:macro>

  <xacro:gripper_contact link_name="robotiq_85_left_finger_tip_link"/>
  <xacro:gripper_contact link_name="robotiq_85_right_finger_tip_link"/>
  <xacro:gripper_contact link_name="robotiq_85_left_finger_link"/>
  <xacro:gripper_contact link_name="robotiq_85_right_finger_link"/>
  <xacro:gripper_contact link_name="robotiq_85_left_inner_knuckle_link"/>
  <xacro:gripper_contact link_name="robotiq_85_right_inner_knuckle_link"/>

</robot>